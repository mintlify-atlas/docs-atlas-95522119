{
  "projectType": "sdk-library",
  "projectName": "AWS SDK for .NET",
  "projectDescription": "The official AWS SDK for .NET, providing modular NuGet packages to integrate .NET applications with Amazon Web Services.",
  "theme": "maple",
  "primaryColor": "#32a2de",
  "lightColor": "#fc655a",
  "darkColor": "#8c949c",
