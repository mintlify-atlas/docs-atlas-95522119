  "keyFeatures": [
    "Modular NuGet packages per AWS service (e.g., AWSSDK.S3, AWSSDK.DynamoDBv2)",
    "Async/await support across all service clients",
    "Automatic credential discovery via credential provider chain",
    "DynamoDB high-level DataModel (object persistence) and DocumentModel APIs",
    "S3 TransferUtility for multipart upload/download",
    "ASP.NET Core dependency injection support via AWSSDK.Extensions.NETCore.Setup",
    "Built-in retry policies (standard, adaptive)",
    "Code analyzers included in NuGet packages for compile-time validation",
    "AWS Common Runtime (CRT) integration for advanced S3 features",
    "Telemetry and observability hooks via TelemetryProvider"
  ],
  "publicApiSurface": [
    "AmazonServiceClient (base class for all service clients)",
    "ClientConfig / IClientConfig",
    "AWSCredentials / BasicAWSCredentials / InstanceProfileAWSCredentials",
    "FallbackCredentialsFactory",
    "CredentialProfileStoreChain / SharedCredentialsFile",
    "IDynamoDBContext / DynamoDBContext",
    "TransferUtility (S3)",
    "AWSConfigs",
    "RegionEndpoint",
    "IServiceCollection.AddDefaultAWSOptions() / AddAWSService<T>()",
    "RetryPolicy / StandardRetryPolicy / AdaptiveRetryPolicy",
    "TelemetryProvider / DefaultTelemetryProvider",
    "AmazonWebServiceRequest / AmazonWebServiceResponse",
    "IEndpointProvider"
  ]
}
